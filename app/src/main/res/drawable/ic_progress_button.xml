<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#401a1a2e"/>
                    <corners
                        android:topLeftRadius="18dp"
                        android:bottomLeftRadius="18dp"
                        android:topRightRadius="0dp"
                        android:bottomRightRadius="0dp"/>
                    <stroke
                        android:width="1dp"
                        android:color="#60BA68C8"/>
                </shape>
            </item>
            <item
                android:drawable="@drawable/ic_arrow_left_white"
                android:gravity="center"/>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#501a1a2e"/>
                    <corners
                        android:topLeftRadius="18dp"
                        android:bottomLeftRadius="18dp"
                        android:topRightRadius="0dp"
                        android:bottomRightRadius="0dp"/>
                    <stroke
                        android:width="1dp"
                        android:color="#40BA68C8"/>
                </shape>
            </item>
            <item
                android:drawable="@drawable/ic_arrow_left_white"
                android:gravity="center"/>
        </layer-list>
    </item>
</selector>
